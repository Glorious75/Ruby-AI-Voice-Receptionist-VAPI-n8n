      "name": "Respond to Webhook"
    },
    {
      "parameters": {
        "jsCode": "const req = $json.body ?? $json;\n\nconst toolCallId =\n  req.toolCallId ||\n  req.message?.toolCallId ||\n  req.message?.toolCallList?.[0]?.id ||\n  req.message?.toolWithToolCallList?.[0]?.toolCall?.id ||\n  req.toolCall?.id ||\n  req.id ||\n  \"\";\n\nconst text =\n  req.message?.content ||\n  req.message?.text ||\n  req.transcript ||\n  JSON.stringify(req);\n\n// crude extraction for testing\nconst emailMatch = String(text).match(/[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}/i);\nconst phoneMatch = String(text).match(/\\b0\\d{10}\\b|\\b\\d{10,15}\\b/);\n\n// try name after phrases like \"my name is ...\"\nconst nameMatch = String(text).match(/my name is\\s+([A-Za-z]+(?:\\s+[A-Za-z]+){0,2})/i);\n\nconst email = emailMatch ? emailMatch[0] : \"\";\nconst phone = phoneMatch ? phoneMatch[0] : \"\";\nconst name = nameMatch ? nameMatch[1].trim() : \"\";\n\nreturn [\n  {\n    json: {\n      toolCallId,\n      name,\n      phone,\n      email\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
