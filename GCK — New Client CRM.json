    {
      "parameters": {
        "jsCode": "const original = $(\"Code in JavaScript\").first().json;\nconst toolCallId = original.toolCallId || \"\";\n\nconst name = original.name || \"customer\";\n\nreturn [\n  {\n    json: {\n      results: [\n        {\n          toolCallId: String(toolCallId),\n          result: `New client created successfully for ${name}.`\n        }\n      ]\n    }\n  }\n];"
      },
